<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.amazon.news.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/taoxue/personal/amazon-news/scripts/daily_news.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/taoxue/personal/amazon-news/output/news/launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/taoxue/personal/amazon-news/output/news/launchd.err</string>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
