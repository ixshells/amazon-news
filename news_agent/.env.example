# ============================================================
# 新闻情报系统 - 环境变量配置
# 复制此文件为 .env 并填写
# ============================================================

# ---- AI 模型配置 ----
# 可选: openai / anthropic / ollama
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
# 可选: 使用兼容 API 的地址（如 DeepSeek、Groq 等）
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic 配置
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama 本地模型配置（无需 API Key）
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ---- 新闻来源开关 ----
# 中文来源（默认启用）
ENABLE_AMZ123=true
ENABLE_MJZJ=true               # 卖家之家
ENABLE_IKJZD=false             # 跨境知道（解析器待扩展）
ENABLE_WEARESELLERS=false      # 知无不言（解析器待扩展）

# ---- 爬虫控制 ----
# 请求间隔（秒）
NEWS_DELAY_MIN=2
NEWS_DELAY_MAX=5

# 每个来源最多爬取文章数
MAX_ARTICLES_PER_SOURCE=30

# 请求超时（秒）
NEWS_TIMEOUT=30

# 代理（可选）
# PROXY_URL=http://127.0.0.1:7890

# ---- 输出路径 ----
# NEWS_OUTPUT_DIR=./output/news
